# Secrets — never commit
.env
.env.local
.env.*.local
*.pem

# Python
backend/.venv/
backend/.venv-ci/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Node (when frontend exists)
node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# Playwright (e2e reports and run artifacts)
frontend/playwright-report/
frontend/test-results/

# Local booking document uploads (BOOKING_DOCUMENTS_STORAGE=local)
data/booking-documents/
backend/data/booking-documents/

# Local executed contract PDFs (contract signing)
data/contract-packets/
backend/data/contract-packets/

# Ephemeral vendor dir for CI/agent pytest (reportlab)
backend/.pytest_vendor/

# Local catalog item images (ITEM_IMAGES_STORAGE=local)
data/item-images/
backend/data/item-images/

# Generated / local test assets (e.g. sample license images for dev)
assets/test-fixtures/

