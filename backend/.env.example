SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated browser origins (must match how you open the Vite app, scheme + host + port)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Send as header X-Admin-Token from the admin UI (stub auth)
ADMIN_STUB_TOKEN=dev-admin-change-me
# Booking uploads: supabase Storage bucket booking-documents (default), or local for dev without Storage
BOOKING_DOCUMENTS_STORAGE=supabase
BOOKING_DOCUMENTS_LOCAL_DIR=data/booking-documents
# Links to booking files in admin JSON (use your API origin; LAN dev may need http://192.168.x.x:8000)
API_PUBLIC_URL=http://127.0.0.1:8000
# Catalog item photos: public Storage bucket item-images (default), or local without Supabase Storage
ITEM_IMAGES_STORAGE=supabase
ITEM_IMAGES_LOCAL_DIR=data/item-images
# Optional SMTP — quote + booking confirmation emails (leave empty to skip sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true