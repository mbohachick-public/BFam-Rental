SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Must be the **service_role** secret (long JWT), not the anon "public" key — anon hits RLS and writes fail with 42501.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated browser origins (must match how you open the Vite app, scheme + host + port)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Booking uploads: supabase Storage bucket booking-documents (default), or local for dev without Storage
BOOKING_DOCUMENTS_STORAGE=supabase
BOOKING_DOCUMENTS_LOCAL_DIR=data/booking-documents
# Links to booking files in admin JSON (use your API origin; LAN dev may need http://192.168.x.x:8000)
API_PUBLIC_URL=http://127.0.0.1:8000
# SPA origin for customer signing links in emails (no trailing slash). Use the same host you open in the browser
# (e.g. http://localhost:5173 if Vite prints localhost — mixing with 127.0.0.1 can fail on some setups).
FRONTEND_PUBLIC_URL=http://localhost:5173
# Optional: customer payment-instructions URL on admin approve — use {booking_id} or {id}. Shown in approval emails for non-card paths when set.
# PAYMENT_COLLECTION_URL_TEMPLATE=https://bohachickrentals.com/pay/{booking_id}
# Optional: signing token lifetime (days); default 14
# SIGNING_TOKEN_TTL_DAYS=14
# Executed agreement PDFs + snapshots on disk (relative to backend cwd unless absolute)
# CONTRACT_PACKETS_DIR=data/contract-packets
# Catalog item photos: public Storage bucket item-images (default), or local without Supabase Storage
ITEM_IMAGES_STORAGE=supabase
ITEM_IMAGES_LOCAL_DIR=data/item-images
# Optional SMTP — quote, booking confirmation, signature receipt, and Stripe checkout link emails
# (leave empty to skip sending; admin “generate payment links” still creates Stripe sessions but will not email the customer).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional Auth0: when BOTH are set, POST /booking-requests and /booking-requests/quote require Authorization: Bearer <access_token> with aud = this identifier. JWKS is loaded from the issuer in the token; hostname must be AUTH0_DOMAIN or listed in AUTH0_DOMAIN_ALIASES.
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# When using Auth0 custom domain on the SPA, set AUTH0_DOMAIN to that host or add it: AUTH0_DOMAIN_ALIASES=login.yourdomain.com
# AUTH0_AUDIENCE=https://your-api-identifier
# Admin UI/API: same Bearer token as customers, plus one of the checks below (defaults: role name "admin").
AUTH0_ADMIN_ROLES=admin
# AUTH0_ADMIN_ROLES_CLAIM=https://your.app/roles
# AUTH0_ADMIN_EMAILS=you@example.com
# Optional: JWT "sub" allowlist when the access token has no roles/email (decode a token at jwt.io or copy from Auth0 user profile).
AUTH0_ADMIN_SUBS=google-oauth2|104461662499041463444

# Sales tax (quotes + bookings): each request does a fresh lookup — no caching.
# Option A — Live JSON GET: URL with {zip} or {ZIP}, or base URL (postal_code query param is appended).
#   Response JSON must include rate_percent, combined_rate_percent, total_rate_percent, sales_tax_percent (percent, e.g. 8.475), or rate (0–1 or percent).
# Option B — Fallback only (dev / no proxy yet): set SALES_TAX_FALLBACK_PERCENT (e.g. 4.225). Missouri DOR has no simple public rate API; host your own reader of official data if you need live rates.
# SALES_TAX_RATE_URL=https://your-proxy.example/rates/{zip}
# SALES_TAX_FALLBACK_PERCENT=4.225
# Used when quote body omits tax_postal_code and booking address has no ZIP:
# SALES_TAX_DEFAULT_POSTAL_CODE=64089
# SALES_TAX_HTTP_TIMEOUT_SEC=8

# Stripe Checkout (rental total after customer signed). Test keys from Stripe Dashboard.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Signing secret from Developers → Webhooks → your endpoint
# Optional: override success/cancel redirect origin (defaults to FRONTEND_PUBLIC_URL)
# APP_BASE_URL=https://your-spa.example.com
# When true (default), API creates a second Stripe Checkout session for the security deposit
# (separate PaymentIntent). Card-path Stripe links are created on approve / resend-signature and are
# included in that same customer email with the signing link (no separate checkout-only email).
# Requires DB migration Specs/supabase-migration-stripe-separate-deposit-checkout.sql
# (otherwise PostgREST errors on stripe_deposit_checkout_* columns).
# STRIPE_CHECKOUT_INCLUDE_DEPOSIT=false

# Google Distance Matrix (server-side only) — used when delivery is enabled and a customer requests delivery.
# See Specs/supabase-migration-delivery-pricing.sql for delivery_settings + booking_requests columns.
# GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_HTTP_TIMEOUT_SEC=12