# Local dev: leave unset or use `proxy` so requests go to /api and Vite forwards to port 8000 (recommended).
# Or set a full URL, e.g. http://127.0.0.1:8000 — restart `npm run dev` after changes.
# VITE_API_URL=proxy
#
# Production — pick ONE pattern (see Specs/Deployment-Environments.md):
# (A) Same host: reverse-proxy /api to the API; build may still use proxy or relative /api per host config.
# (B) Split hosts: set full API origin, e.g. VITE_API_URL=https://api.yourdomain.com
# VITE_API_URL=https://api.yourdomain.com
# Same value as backend ADMIN_STUB_TOKEN (used when you sign in on /admin/login)
VITE_ADMIN_STUB_TOKEN=dev-admin-change-me

# Optional Auth0 (customer sign-in). When VITE_AUTH0_DOMAIN and VITE_AUTH0_CLIENT_ID are set, the SPA shows Sign in / Sign out and sends Bearer tokens for quote + booking. Must match Auth0 Application settings (Callback / Logout / Web Origins = this app origin). VITE_AUTH0_AUDIENCE must match backend AUTH0_AUDIENCE when the API enforces JWT.
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Optional — real Auth0 Universal Login e2e (see e2e/auth0-login.spec.ts). Requires DB user (no MFA).
# E2E_AUTH0_EMAIL=testuser@example.com
# Quote passwords that contain # (otherwise # starts a comment in .env).
# E2E_AUTH0_PASSWORD="your-secret#with-hash"
