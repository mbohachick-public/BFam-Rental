# Local dev: leave unset or use `proxy` so requests go to /api and Vite forwards to port 8000 (recommended).
# Or set a full URL, e.g. http://127.0.0.1:8000 — restart `npm run dev` after changes.
# VITE_API_URL=proxy
# Same value as backend ADMIN_STUB_TOKEN (used when you sign in on /admin/login)
VITE_ADMIN_STUB_TOKEN=dev-admin-change-me
